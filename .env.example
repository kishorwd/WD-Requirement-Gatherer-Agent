# DeepSeek API Configuration
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="your_api_key_here"

# LLM Model Configuration
# deepseek-v4-pro  → Complex reasoning: scope analysis, MoM, briefing overview, story generation
# deepseek-v4-flash → Fast extraction: speaker names, discovery questions, submodule enumeration
LLM_MODEL_PRO="deepseek-v4-pro"
LLM_MODEL_FLASH="deepseek-v4-flash"
LLM_MAX_OUTPUT_TOKENS="8192"
LLM_MAX_INPUT_CHARS="500000"

# Feature Toggles
ENABLE_BATCHED_DISCOVERY="1"
DISCOVERY_BATCH_SIZE="8"

# Backend Configuration
DATABASE_URL="sqlite:///./requirements.db"
PORT=8001
HOST="0.0.0.0"
